				"storage.type",
				"storage.type.class",
				"entity.name.function.constructor"
			],
			"settings": {
				"foreground": "#DEBA91"
			}
		},
		{
			"name": "string",
			"scope": [
				"string"
			],
			"settings": {
				"foreground": "#93B881"
			}
		},
		{
			"name": "support",
