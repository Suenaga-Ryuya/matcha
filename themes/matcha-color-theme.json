	"tokenColors": [
		{
			"name": "comment",
			"scope": [
				"comment",
				"comment.line",
				"punctuation.definition.comment"
			],
			"settings": {
				"fontStyle": "italic",
			 	"foreground": "#6a6b60"
			}
		},
		{
			"name": "constant",
			"scope": [
				"constant"
			],
			"settings": {
				"foreground": "#84a1a8"
			}
		},
		{
			"name": "entity",
			"scope": [
				"entity"
			],
			"settings": {
				"foreground": "#837282"
			}
		},
		{
			"name": "invalid",
			"scope": [
				"invalid"
			],
			"settings": {
				"foreground": "#E24215"
			}
		},
		{
			"name": "keyword",
			"scope": [
